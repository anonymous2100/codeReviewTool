# AI Provider Configuration (supports DeepSeek, Zhipu, Kimi, Doubao via OpenAI-compatible API)
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-coder

# GitLab Configuration
GITLAB_TOKEN=glpat-your-gitlab-token-here
GITLAB_BASE_URL=https://gitlab.com/api/v4

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret-here

# Application
APP_PORT=8099
SPRING_PROFILES_ACTIVE=prod

# Database (MySQL default; prod profile uses PostgreSQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=reviewbot
DB_PASSWORD=your-db-password-here
DB_ROOT_PASSWORD=your-root-password-here

# Docker Image
IMAGE_TAG=latest
